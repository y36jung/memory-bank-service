# App
PORT=3000
NODE_ENV=development

# Postgres credentials (used by docker-compose.yml)
POSTGRES_DB=...
POSTGRES_USER=...
POSTGRES_PASSWORD=...

# App connection string (used by Drizzle / pg pool)
DATABASE_URL=...

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# pgAdmin GUI
PGADMIN_DEFAULT_EMAIL=...
PGADMIN_DEFAULT_PASSWORD=...

# Auth
JWT_SECRET=...

# OpenAI
OPENAI_API_KEY=...

# AWS S3 document storage
AWS_REGION=...
S3_BUCKET_NAME=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
