# Base URL of a running Memory Bank instance
MEMORY_BANK_API_URL=http://localhost:3000

# Dedicated eval user — registered idempotently by scripts/setup.mjs on first run
EVAL_USER_EMAIL=rag-eval@memorybank.local
EVAL_USER_PASSWORD=change-me-eval-password-min-8-chars

# Used by promptfoo's llm-rubric assertions (grading), separate from whatever
# key the Memory Bank server itself uses for GPT-4o/embeddings
OPENAI_API_KEY=
